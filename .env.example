# Embedding 服务配置
EMBEDDING_PORT=8001
EMBEDDING_MODEL=BAAI/bge-large-zh-v1.5
KEYWORD_EXTRACT_ENABLED=true  # 由本地 light_rag 控制，非 Docker 服务

# Chroma 配置
CHROMA_PORT=8000
# CHROMA_AUTH_PROVIDER=
# CHROMA_AUTH_CREDENTIALS=

# Reranker 配置（扩展点）
# RERANKER_PORT=8002
# RERANK_MODEL=BAAI/bge-reranker-v2-m3
RERANK_CANDIDATES=5

# HuggingFace 缓存目录
HF_CACHE_DIR=~/.cache/huggingface
